<Window x:Class="ProformaLogytronic.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuración"
        Height="440" Width="600"
        MinHeight="360" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        FontFamily="Segoe UI" FontSize="14"
        Background="#F5F6F8">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="Configuración" FontSize="22" FontWeight="SemiBold" Foreground="#333"/>
            <TextBlock Text="Preferencias de la aplicación" Margin="0,6,0,16" Foreground="#666" FontSize="14"/>
        </StackPanel>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20"
                BorderBrush="#E0E0E0" BorderThickness="1" VerticalAlignment="Stretch">
            <StackPanel>
                <TextBlock Text="Carpeta para guardar PDF" FontWeight="SemiBold" FontSize="16" Foreground="#333" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" Foreground="#666" FontSize="13" Margin="0,0,0,14"
                           Text="Los PDF se organizan en Proformas\Año\nombre del mes (por ejemplo Mayo) dentro de la ruta que elijas."/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PdfFolderPathTextBox" Grid.Column="0" Margin="0,0,10,0"
                             Padding="8,6" VerticalContentAlignment="Center"
                             ToolTip="Ruta absoluta de la carpeta base (opcional)"/>
                    <Button Grid.Column="1" Content="Examinar…" Click="Examinar_Click" Padding="14,8"
                            Background="#E5F3FF" BorderThickness="0" Foreground="#005A9E" FontWeight="SemiBold" Cursor="Hand"/>
                </Grid>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Aplicar cambios" Click="AplicarCambios_Click" Padding="22,10"
                    Background="#0078D7" Foreground="White" FontWeight="SemiBold" Cursor="Hand" BorderThickness="0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#005A9E"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#004578"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
